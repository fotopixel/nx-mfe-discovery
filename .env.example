# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and will not be committed.

# The Frontend Discovery Service exposes two APIs from a single deployment:
#   - Admin API (Cognito-protected): for publishing versions and managing deployments
#   - Consumer API (public, edge-replicated): for fetching the MFE manifest
#
# Environments are modeled as separate Projects within the same service.
# The projectId in the URL path selects the environment.

# Consumer API endpoint for your staging project.
# Format: {consumerApiUrl}/{stage}/{stagingProjectId}/microFrontends
STAGING_DISCOVERY_ENDPOINT=https://YOUR_CONSUMER_API.execute-api.eu-west-1.amazonaws.com/prod/YOUR_STAGING_PROJECT_ID/microFrontends

# Host app discovery endpoint (points to local proxy in dev)
NX_DISCOVERY_ENDPOINT=http://localhost:4300/microFrontends

# For deployed environments, the discovery endpoint is injected at deploy time
# via a <meta> tag in index.html, not baked into the build:
#   <meta name="discovery-endpoint" content="{consumerApiUrl}/{stage}/{projectId}/microFrontends">
