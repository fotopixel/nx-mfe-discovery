# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and will not be committed.
# A symlink .env -> .env.local is used so the REST Client extension can read it.

# Consumer API endpoint for your staging project.
# Format: {consumerApiUrl}/projects/{projectId}/microFrontends
STAGING_DISCOVERY_ENDPOINT=https://YOUR_CONSUMER_API.execute-api.eu-central-1.amazonaws.com/prod/projects/YOUR_STAGING_PROJECT_ID/microFrontends
PRODUCTION_DISCOVERY_ENDPOINT=https://YOUR_CONSUMER_API.execute-api.eu-central-1.amazonaws.com/prod/projects/YOUR_PRODUCTION_PROJECT_ID/microFrontends

# Host app discovery endpoint (points to local proxy in dev)
NX_DISCOVERY_ENDPOINT=http://localhost:4300/microFrontends

# Discovery Service API URLs (used by REST Client .http files)
DISCOVERY_ADMIN_API=https://YOUR_ADMIN_API.execute-api.eu-central-1.amazonaws.com/prod
DISCOVERY_CONSUMER_API=https://YOUR_CONSUMER_API.execute-api.eu-central-1.amazonaws.com/prod

# Project IDs
STAGING_PROJECT_ID=
PRODUCTION_PROJECT_ID=

# Cognito auth (for Admin API token)
COGNITO_REGION=eu-central-1
COGNITO_CLIENT_ID=
COGNITO_USERNAME=
COGNITO_PASSWORD=

# Paste IdToken from auth.http response here (expires after ~1h)
DISCOVERY_TOKEN=
